# ============================================================
# AI TRAVEL PLANNER — ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to version control.

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development                        # development | staging | production

# ─── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/travel_planner?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/travel_planner?schema=public"
# DIRECT_URL is used by Prisma for migrations (bypass connection pooler like PgBouncer)

# ─── Authentication (NextAuth v5) ───────────────────────────
AUTH_SECRET="your-super-secret-auth-secret-min-32-chars"
AUTH_URL=http://localhost:3000

# OAuth Providers
AUTH_GOOGLE_ID="your-google-oauth-client-id"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"
AUTH_GITHUB_ID="your-github-oauth-client-id"
AUTH_GITHUB_SECRET="your-github-oauth-client-secret"
AUTH_FACEBOOK_ID="your-facebook-app-id"
AUTH_FACEBOOK_SECRET="your-facebook-app-secret"

# Feature flags (set to "false" to disable)
NEXT_PUBLIC_ENABLE_FACEBOOK_LOGIN=true

# ─── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o"                     # gpt-4o | gpt-4o-mini | gpt-4-turbo
OPENAI_MAX_TOKENS=4096

# ─── Mapbox ─────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN="pk.eyJ1..."
MAPBOX_SECRET_TOKEN="sk.eyJ1..."

# ─── Weather API (Open-Meteo is free, no key needed) ────────
# Or use OpenWeatherMap:
OPENWEATHER_API_KEY="your-openweather-api-key"
NEXT_PUBLIC_WEATHER_API_URL=https://api.open-meteo.com/v1

# ─── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs (create these in Stripe Dashboard)
STRIPE_PRICE_PRO_MONTHLY="price_..."
STRIPE_PRICE_PRO_YEARLY="price_..."

# ─── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="AI Travel Planner <noreply@yourdomain.com>"

# ─── Feature Flags ──────────────────────────────────────────
NEXT_PUBLIC_ENABLE_COLLABORATION=true
NEXT_PUBLIC_ENABLE_WEATHER=true
NEXT_PUBLIC_ENABLE_PDF_EXPORT=true

# ─── Admin ──────────────────────────────────────────────────
ADMIN_EMAIL="admin@yourdomain.com"

# ─── Rate Limiting ──────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."

# ─── Analytics (Optional) ───────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
